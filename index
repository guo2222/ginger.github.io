  <style>
    :root {
      --bg: #f5f8fc;
      --card: #ffffff;
      --primary: #0b5cab;
      --primary-deep: #083b73;
      --text: #1f2937;
      --subtext: #5b6472;
      --line: #d9e3f0;
      --tag-bg: #eaf2fb;
      --shadow: 0 10px 30px rgba(11, 92, 171, 0.08);
      --radius: 18px;
      --maxw: 1080px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      background: linear-gradient(180deg, #eef4fb 0%, #f8fbff 100%);
      color: var(--text);
      line-height: 1.7;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      width: min(calc(100% - 32px), var(--maxw));
      margin: 0 auto;
    }

    .hero {
      padding: 42px 0 22px;
    }

    .hero-card {
      background: linear-gradient(135deg, #0b5cab 0%, #0b6fc7 45%, #1f88df 100%);
      color: #fff;
      border-radius: 24px;
      box-shadow: 0 18px 40px rgba(11, 92, 171, 0.18);
      padding: 28px;
      position: relative;
      overflow: hidden;
    }

    .hero-card::after {
      content: "";
      position: absolute;
      right: -60px;
      top: -60px;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.08);
    }

    .hero-top {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: flex-start;
      position: relative;
      z-index: 1;
    }

    .name {
      font-size: 34px;
      font-weight: 800;
      letter-spacing: 0.5px;
      margin: 0;
    }

    .subtitle {
      margin: 10px 0 0;
      font-size: 15px;
      opacity: 0.96;
    }

    .meta {
      margin-top: 18px;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .meta span,
    .tags span {
      display: inline-flex;
      align-items: center;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 13px;
      background: rgba(255, 255, 255, 0.14);
      border: 1px solid rgba(255, 255, 255, 0.18);
      backdrop-filter: blur(6px);
    }

    .quick-nav {
      margin: 18px 0 0;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      position: relative;
      z-index: 1;
    }

    .quick-nav a {
      padding: 9px 14px;
      border-radius: 12px;
      font-size: 13px;
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(255, 255, 255, 0.1);
      transition: 0.2s ease;
    }

    .quick-nav a:hover {
      background: rgba(255, 255, 255, 0.18);
      transform: translateY(-1px);
    }

    .note {
      margin-top: 14px;
      font-size: 13px;
      opacity: 0.9;
      position: relative;
      z-index: 1;
    }

    .layout {
      display: grid;
      grid-template-columns: 300px minmax(0, 1fr);
      gap: 22px;
      padding: 22px 0 36px;
    }

    .sidebar,
    .content-section,
    .project-card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .sidebar {
      padding: 18px;
      position: sticky;
      top: 18px;
      height: fit-content;
    }

    .side-title,
    .section-title {
      margin: 0 0 12px;
      color: var(--primary-deep);
      font-size: 18px;
      font-weight: 800;
    }

    .side-block + .side-block {
      margin-top: 22px;
      padding-top: 18px;
      border-top: 1px solid var(--line);
    }

    .contact-list,
    .summary-list {
      display: grid;
      gap: 10px;
      font-size: 14px;
      color: var(--subtext);
    }

    .label {
      display: inline-block;
      min-width: 64px;
      color: var(--primary-deep);
      font-weight: 700;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .tags span {
      background: var(--tag-bg);
      color: var(--primary-deep);
      border: 1px solid #d6e6fa;
      font-size: 12px;
      font-weight: 600;
      padding: 7px 12px;
    }

    .content {
      display: grid;
      gap: 18px;
    }

    .content-section {
      padding: 22px;
    }

    .section-title {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 14px;
    }

    .section-title::before {
      content: "";
      width: 6px;
      height: 20px;
      border-radius: 999px;
      background: linear-gradient(180deg, var(--primary) 0%, #57a8ea 100%);
    }

    .section-text {
      color: var(--text);
      font-size: 15px;
    }

    .section-text p {
      margin: 0 0 12px;
    }

    .projects-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 14px;
      flex-wrap: wrap;
    }

    .project-count {
      font-size: 13px;
      color: var(--subtext);
      padding: 6px 10px;
      border-radius: 999px;
      background: #f3f7fc;
      border: 1px solid var(--line);
    }

    .projects-grid {
      display: grid;
      gap: 16px;
    }

    .project-card {
      padding: 18px;
      transition: 0.2s ease;
    }

    .project-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 34px rgba(11, 92, 171, 0.12);
    }

    .project-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 10px;
    }

    .project-name {
      margin: 0;
      font-size: 18px;
      font-weight: 800;
      color: var(--primary-deep);
      line-height: 1.4;
    }

    .project-time {
      white-space: nowrap;
      font-size: 13px;
      color: var(--primary);
      background: #edf5ff;
      border: 1px solid #d7e8fb;
      padding: 6px 10px;
      border-radius: 999px;
      font-weight: 700;
    }

    .role-line {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 12px;
    }

    .role-badge {
      display: inline-flex;
      align-items: center;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      color: var(--primary-deep);
      background: var(--tag-bg);
      border: 1px solid #d7e8fb;
    }

    .project-block {
      margin-top: 10px;
    }

    .project-block-title {
      font-size: 14px;
      font-weight: 800;
      color: var(--primary-deep);
      margin-bottom: 8px;
    }

    .project-block p {
      margin: 0;
      font-size: 14px;
      color: var(--text);
    }

    .project-block ul {
      margin: 0;
      padding-left: 20px;
      color: var(--text);
    }

    .project-block li {
      margin: 6px 0;
      font-size: 14px;
    }

    .footer {
      padding: 10px 0 40px;
      color: var(--subtext);
      font-size: 13px;
      text-align: center;
    }

    .back-top {
      position: fixed;
      right: 18px;
      bottom: 18px;
      width: 46px;
      height: 46px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: var(--primary);
      color: #fff;
      box-shadow: 0 12px 24px rgba(11, 92, 171, 0.22);
      border: none;
      cursor: pointer;
      font-size: 18px;
    }

    @media (max-width: 920px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .sidebar {
        position: static;
      }
    }

    @media (max-width: 640px) {
      .container {
        width: min(calc(100% - 20px), var(--maxw));
      }

      .hero {
        padding-top: 18px;
      }

      .hero-card {
        padding: 20px;
        border-radius: 20px;
      }

      .hero-top,
      .project-top,
      .projects-head {
        flex-direction: column;
        align-items: flex-start;
      }

      .name {
        font-size: 28px;
      }

      .content-section,
      .project-card,
      .sidebar {
        padding: 16px;
      }

      .project-time {
        white-space: normal;
      }
    }
  </style>
</head>
